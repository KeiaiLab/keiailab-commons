# 디렉토리/파일별 자동 리뷰어 매핑 (4-repo 통일 — 라이브러리 minimal)
# 형식: <pattern> <owner>
# 참고: https://docs.github.com/en/repositories/managing-your-repositories-settings-and-features/customizing-your-repository/about-code-owners

# 전체 기본 소유자 (team-based — RFC 0008 governance template propagation 정합)
* @keiailab/maintainers

# 핵심 라이브러리 패키지 (downstream 3 operator 가 의존)
/pkg/labels/                @keiailab/maintainers
/pkg/security/              @keiailab/maintainers
/pkg/version/               @keiailab/maintainers
/pkg/webhook/               @keiailab/maintainers
/pkg/networkpolicy/         @keiailab/maintainers
/pkg/monitoring/            @keiailab/maintainers

# 빌드/배포
/.github/                   @keiailab/maintainers
/Makefile                   @keiailab/maintainers
/go.mod                     @keiailab/maintainers
/go.sum                     @keiailab/maintainers
/renovate.json              @keiailab/maintainers

# 문서/거버넌스
/docs/                      @keiailab/maintainers
/README.md                  @keiailab/maintainers
/README.ko.md               @keiailab/maintainers @eightynine01
/LICENSE                    @keiailab/maintainers
/NOTICE                     @keiailab/maintainers
/docs/MAINTAINERS.md             @keiailab/maintainers
/scripts/check-readme-sync.sh  @keiailab/maintainers
